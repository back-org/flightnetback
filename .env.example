# FlightNet - Variables d'environnement
# Copiez ce fichier en .env et modifiez les valeurs selon votre environnement

# ─── Base de données ─────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=flightnet
MYSQL_USER=flightuser
MYSQL_PASSWORD=flightpass
DB_CONNECTION_STRING=

# ─── Application ─────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# ─── JWT ─────────────────────────────────────────────────────
# Changez obligatoirement cette valeur en production !
JWT_SECRET=superSecretKey@345FlightNet2024!
