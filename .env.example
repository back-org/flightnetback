# ============================================================
# FLIGHTNET ENVIRONMENT CONFIGURATION
# ============================================================

# ------------------------------------------------------------
# ASP.NET Core configuration
# ------------------------------------------------------------

# Environment utilisé par ASP.NET
ASPNETCORE_ENVIRONMENT=Development

# Port exposé par l'API
ASPNETCORE_PORT=8080


# ------------------------------------------------------------
# DATABASE CONFIGURATION (MYSQL)
# ------------------------------------------------------------

# Root password MySQL
MYSQL_ROOT_PASSWORD=rootpassword

# Nom de la base
MYSQL_DATABASE=flightnet

# Utilisateur applicatif
MYSQL_USER=flightuser

# Mot de passe utilisateur
MYSQL_PASSWORD=flightpass

# Port MySQL local
MYSQL_PORT=3306


# ------------------------------------------------------------
# CONNECTION STRING (pour docker-compose)
# ------------------------------------------------------------

# La connection string sera reconstruite automatiquement
# dans docker-compose via :
#
# ConnectionStrings__DbConn
#
# Format final :
#
# Server=db;Port=3306;Database=flightnet;
# Uid=flightuser;Pwd=flightpass;


# ------------------------------------------------------------
# JWT CONFIGURATION
# ------------------------------------------------------------

# Secret utilisé pour signer les tokens
JWT_SECRET=63f4945d921d599f27ae4fdf5bada3f1

# Issuer du token
JWT_ISSUER=FlightNet

# Audience du token
JWT_AUDIENCE=FlightNetClient

# Durée de validité access token (minutes)
JWT_ACCESS_EXPIRATION=20

# Durée refresh token (minutes)
JWT_REFRESH_EXPIRATION=60


# ------------------------------------------------------------
# ADMINER CONFIGURATION (DEV)
# ------------------------------------------------------------

# Port interface Adminer
ADMINER_PORT=8888


# ------------------------------------------------------------
# OPTIONAL FEATURES
# ------------------------------------------------------------

# Activer les logs SQL EF Core
EF_LOG_SQL=false

# Activer logs détaillés
LOG_LEVEL=Information


# ------------------------------------------------------------
# TESTS CONFIGURATION
# ------------------------------------------------------------

# Base utilisée pour les tests d'intégration
TEST_DATABASE=flightnet_test

# Timeout des tests
TEST_TIMEOUT=30